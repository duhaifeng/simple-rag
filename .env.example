# === SimpleRAG Environment Variables ===

# --- PostgreSQL (pgvector) ---
RAG_PG_DSN=postgresql+asyncpg://postgres:postgres@localhost:5432/simple_rag

# --- Local storage directory (for raw docs / parsed artifacts) ---
RAG_STORAGE_DIR=./data/storage

# --- Profiles config path (default: configs/profiles.yaml) ---
# RAG_PROFILES_PATH=./configs/profiles.yaml

# --- Server ---
RAG_HOST=0.0.0.0
RAG_PORT=8000
RAG_DEBUG=true

# --- Remote Embedding Service (used when profile = corp_service) ---
# EMBEDDINGS_BASE_URL=https://your-corp-embedding.example.com
# EMBEDDINGS_API_KEY=your-api-key

# --- Remote Rerank Service (used when profile = corp_service) ---
# RERANK_URL=https://your-corp-rerank.example.com
# RERANK_API_KEY=your-api-key

# --- Qdrant (used when vector_store profile = local_qdrant) ---
# QDRANT_API_KEY=

# --- Vue 3 Frontend ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
